{ Stage 1: Strip Script and Style Tags

  Purpose: Remove <script> and <style> blocks entirely

  Input:  <div>Before<script>bad();</script>After</div>
  Output: <div>BeforeAfter</div>
}

html: content* .

content: script-block | style-block | text .

{ Strip script blocks - everything from <script to </script> }
-script-block: "<script", ~["<"]*, "</script>" .

{ Strip style blocks - everything from <style to </style> }
-style-block: "<style", ~["<"]*, "</style>" .

{ Everything else passes through as-is }
text: text-char+ .
text-char: ~["<"] | "<", ~["s"] | "<s", ~["c"; "t"] .
