{ Form Instructions Grammar

  Purpose: Extract form fields and actions for LLM interaction

  Input:  Linearized HTML after preprocessing
  Output: Clean XML with fields and actions

  Example Input:
    form action="/login" label Email: /label input type="email" name="email" label Password: /label input type="password" name="pwd" input type="submit" value="Login" /form

  Example Output:
    <form action="/login">
      <field>
        <label>Email:</label>
        <input type="email" name="email"/>
      </field>
      <field>
        <label>Password:</label>
        <input type="password" name="pwd"/>
      </field>
      <action value="Login"/>
    </form>
}

page: item* .

item: form | other .

{ Form element }
form: "form", attrs, content*, "/form" .

content: field | submit-action | skip .

{ Field: label followed by input }
field: "label", label-attrs?, label-content, "/label", input-elem .

label-content: words .

input-elem: "input", attrs .

{ Submit action }
submit-action: "input", attrs-with-submit .

attrs-with-submit: attrs .

{ Attributes - everything until next keyword }
attrs: word* .
label-attrs: word* .

{ Words and text }
words: word+ .
word: text-word, -ws .
text-word: chars .
chars: char+ .
char: ~[" "; "/"]+ .

{ Skip elements we don't need }
-skip: "div" | "/div" | "span" | "/span" | "br" | "p" | "/p" .

{ Other top-level content }
-other: word .

-ws: " "* .
