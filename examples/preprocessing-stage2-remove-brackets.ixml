{ Stage 2: Remove Angle Brackets

  Purpose: Remove < and > to linearize HTML

  Input:  <div class="foo">Hello</div>
  Output: div class="foo" Hello /div
}

html: item+ .

item: tag | text .

{ Tags: opening, closing, or void }
tag: opening-tag | closing-tag .

{ Opening tag: <div class="foo"> becomes: div class="foo" }
opening-tag: -"<", tag-content, -">" .

{ Closing tag: </div> becomes: /div }
closing-tag: -"<", "/", tag-content, -">" .

{ Everything between < and > }
tag-content: ~[">"]+ .

{ Text between tags }
text: ~["<"]+ .
