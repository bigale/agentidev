{ Form Structure Grammar - Ultra Simple

  Match: form [words] label [words] input [words] ...

  Input:  form action="/login" label Email: input type="email" name="email"
  Output: Fields extracted
}

document: "form", stuff .

stuff: -" ", item, stuff | "" .

item: field-pattern | word .

{ Try to match label...input pattern }
field-pattern: "label", -" ", label-text, -" ", "input", input-attrs .

label-text: not-input-keyword .

input-attrs: -" ", word, input-attrs | "" .

{ Match anything except the literal word "input" }
not-input-keyword: other-word .

other-word: ~["i"]+ | "i", ~["n"] | "in", ~["p"] | "inp", ~["u"] | "inpu", "t"+ .

word: ~[" "]+ .
