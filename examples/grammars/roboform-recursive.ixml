{ Recursive Grammar for Nested Forms }

document: -"|form", -attrs?, -"|", -s?, form-content*, -"|/form|" .

-attrs: " ", ~["|"]+ .

form-content: -s?, (input-el | select-el | div-el | other-el), -s? .

input-el: -"|input ", input-attrs, -"|" .
input-attrs: ~["|"]+ .

select-el: -"|SELECT ", select-attrs, -"|", any-until-close, -"|/SELECT|"
         | -"|select ", select-attrs, -"|", any-until-close, -"|/select|" .
select-attrs: ~["|"]+ .
-any-until-close: (text-chunk | pipe-chunk)* .
-text-chunk: ~["|"]+ .
-pipe-chunk: "|", ~["/"]+ .

div-el: -"|div", -attrs?, -"|", form-content*, -"|/div|" .

other-el: -"|", -tag-name, -attrs?, -"|", -s?, form-content*, -"|/", -tag-name, -"|"
        | -"|", -tag-name, -attrs?, -"|" .

-tag-name: ["a"-"z", "A"-"Z"]+ .

-s: -~["|"]+ .
