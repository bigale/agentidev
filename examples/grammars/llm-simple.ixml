{ LLM Simple Form Grammar

  Focus: Clean structure, raw attributes for now
}

document: form .

form: -"|form", -form-attrs?, -"|", content*, -"|/form|" .

form-attrs: -" ", -~["|"]+ .

content: field | action | other .

{ Field: label + input }
field: -"|label", -label-attrs?, -"|", label-text, -"|/label||input ", input-attrs, -"|" .

label-attrs: -" ", -~["|"]+ .

label-text: ~["|"]+ .

input-attrs: ~["|"]+ .

{ Action: submit input }
action: -"|input ", action-attrs, -"|" .

action-attrs: ~["|"]+ .

{ Other tags (skip) }
-other: -"|", -~["|"]*, -"|" .
