{ Pipe-Delimited Form Grammar }

document: form .

form: "|form", form-attrs?, "|", form-items*, "|/form|" .

form-attrs: " ", attrs .

form-items: field | input-alone | other .

field: "|label", label-attrs?, "|", label-content, "|/label||input ", input-attrs, "|" .

label-attrs: " ", attrs .

label-content: ~["|"]+ .

input-attrs: attrs .

input-alone: "|input ", attrs, "|" .

attrs: word, (" ", word)* .

word: ~[" |"]+ .

other: "|", ~["|"]*, "|" .
