{ LLM Simple Form Grammar - rustixml compatible

  Minimal version - just get structure working
}

document: form .

form: -"|form", form-rest .

form-rest: -" ", -[^|]+, -"|", content*, -"|/form|"
         | -"|", content*, -"|/form|" .

content: field | action | skip .

field: -"|label", field-rest .

field-rest: -" ", -[^|]+, -"|", label-text, -"|/label||input ", input-attrs, -"|"
          | -"|", label-text, -"|/label||input ", input-attrs, -"|" .

label-text: [^|]+ .

input-attrs: [^|]+ .

action: -"|input ", action-attrs, -"|" .

action-attrs: [^|]+ .

-skip: -"|", -[^|]*, -"|" .
