{ Level 1 HTML Preprocessing Grammar

  Purpose: Remove angle brackets from element.outerHTML

  Input:  <div class="foo">Hello</div>
  Output: div class="foo" Hello /div
}

html: item+ .

item: script-block | style-block | element | text .

{ Strip script tags entirely - match <script...>......</script> }
-script-block: "<script", script-rest .
-script-rest: ~["<"]*, "</script>" .

{ Strip style tags entirely - match <style...>......</style> }
-style-block: "<style", style-rest .
-style-rest: ~["<"]*, "</style>" .

{ Any HTML element }
element: opening-tag | closing-tag | void-element .

{ Opening tag: <div class="foo"> becomes: div class="foo" }
opening-tag: -"<", tag-name, attributes?, -">" .

{ Closing tag: </div> becomes: /div }
closing-tag: -"<", "/", tag-name, -">" .

{ Void elements (self-closing) }
void-element: -"<", void-name, attributes?, -">" .

void-name: "area" | "base" | "br" | "col" | "embed" | "hr" | "img"
         | "input" | "link" | "meta" | "param" | "source" | "track" | "wbr" .

tag-name: letter, name-char* .

attributes: -" ", attr-rest .
attr-rest: attr-char+ .
-attr-char: ~[">"] .

{ Text between tags }
text: text-char+ .
-text-char: ~["<"] .

-letter: ["a"-"z"; "A"-"Z"] .
-name-char: letter | ["0"-"9"] | "-" .
