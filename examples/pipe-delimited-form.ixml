{ Pipe-Delimited Form Grammar

  Parse pipe-delimited HTML to extract form structure

  Input:  |form action="/login"||label|Email:|/label||input type="email" name="email"|
  Output: Structured form with fields
}

document: form .

form: "|form", form-attrs?, "|", form-items, "|/form|" .

form-attrs: " ", attrs .

form-items: form-item+ .

form-item: item .

item: field | input-alone .

{ Field: label followed by input }
field: "|label", label-attrs?, "|", label-content, "|/label", "||input ", input-attrs, "|" .

label-attrs: " ", attrs .

label-content: text .

input-attrs: attrs .

{ Standalone input (like submit) }
input-alone: "|input ", attrs, "|" .

{ Attributes - space-separated words }
attrs: word, (" ", word)* .

{ Text content }
text: text-char+ .
text-char: [^|] .

{ Words - no spaces or pipes }
word: word-char+ .
word-char: [^ |] .
