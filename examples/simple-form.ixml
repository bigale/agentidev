{ Simple Form Grammar

  Extract form structure from linearized HTML

  Input:  form action="/login" label Email: /label input type="email" name="user" /form
  Output: <form><label>Email:</label><input>type="email" name="user"</input></form>
}

document: token+ .

token: form-start | form-end | label-start | label-end | input-tag | slash | word .

form-start: "form" .
form-end: "/form" .

label-start: "label" .
label-end: "/label" .

input-tag: "input" .

slash: "/" .

word: chars, -" " .
chars: ~[" "]+ .
