{ LLM Instructions Grammar v2

  Purpose: Extract actionable information from linearized HTML for LLM

  Strategy: Match patterns that matter (forms, fields, actions), ignore the rest

  Input:  form action="/submit" label Username: /label input type="text" name="user" input type="submit" value="Login" /form

  Output: <form action="/submit">
            <field label="Username" type="text" name="user"/>
            <action type="submit">Login</action>
          </form>
}

document: content+ .

content: form | text | noise .

{ Forms - the main interactive elements }
form: "form", form-attrs?, -ws, form-content*, -ws, "/form" .

form-content: field | action | noise-in-form .

{ Field: label + input pair }
field: "label", label-attrs?, -ws, field-label, -ws, "/label", -ws, "input", input-attrs .

field-label: text-content .

{ Actions: submit buttons }
action: submit-input | button-element .

submit-input: "input", submit-attrs .

button-element: "button", button-attrs?, -ws, button-text, -ws, "/button" .

button-text: text-content .

{ Attributes }
form-attrs: -ws, attr-text .
label-attrs: -ws, attr-text .
input-attrs: -ws, attr-text .
submit-attrs: -ws, attr-text .
button-attrs: -ws, attr-text .

attr-text: non-tag-word+ .

{ Text content }
text: non-tag-word+ .
text-content: non-tag-word+ .

non-tag-word: ~[" "; "/"; "f"; "l"; "i"; "b"]+ | " " .

{ Noise - elements we skip }
-noise: div-noise | span-noise | br-noise | other-noise .
-noise-in-form: div-noise | span-noise | br-noise .

-div-noise: "div", ~["/"]*, "/div" | "/div" .
-span-noise: "span", ~["/"]*, "/span" | "/span" .
-br-noise: "br" .
-other-noise: ~[" "; "f"; "l"; "i"; "b"; "d"; "s"]+ .

-ws: " "* .
