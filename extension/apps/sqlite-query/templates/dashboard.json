{
  "layout": {
    "_type": "VLayout",
    "ID": "sqliteRoot",
    "width": "100%",
    "height": "100%",
    "padding": 12,
    "membersMargin": 10,
    "members": [
      {
        "_type": "Label",
        "height": 28,
        "contents": "<div style='font-size:17px;font-weight:600;color:#a8b4ff;'>SQLite Query \u2014 CheerpX-powered</div>"
      },
      {
        "_type": "Label",
        "height": 44,
        "contents": "<div style='font-size:11px;color:#888;line-height:1.5;'>Upload a SQLite <code>.db</code> file (via URL), then query it with SQL. The file is written into the CheerpX VM and queried via <code>sqlite3 -json</code>. Results render in the grid below with auto-inferred columns. The extension fetches the URL (CORS-free), CheerpX does the computation \u2014 no direct internet from the VM required.</div>"
      },

      {
        "_type": "SectionStack",
        "height": 96,
        "visibilityMode": "multiple",
        "sections": [
          {
            "title": "1. Load Database",
            "expanded": true,
            "items": [
              {
                "_type": "DynamicForm",
                "ID": "uploadForm",
                "width": "100%",
                "numCols": 3,
                "colWidths": [90, "*", 130],
                "fields": [
                  {
                    "name": "url",
                    "title": "DB URL",
                    "type": "text",
                    "width": "*",
                    "defaultValue": "http://localhost:9877/sample.db",
                    "hint": "URL to a .db file \u2014 served via asset-server or any HTTP endpoint"
                  }
                ]
              },
              {
                "_type": "HLayout",
                "height": 28,
                "membersMargin": 8,
                "members": [
                  {
                    "_type": "Button",
                    "ID": "btnLoad",
                    "title": "Load Database",
                    "width": 120,
                    "_action": "fetchAndLoadGrid",
                    "_messageType": "SQLITE_LOAD_URL",
                    "_payloadFrom": "uploadForm",
                    "_targetGrid": "tablesGrid",
                    "_statusCanvas": "uploadStatus",
                    "_timeoutMs": 120000
                  },
                  {
                    "_type": "HTMLFlow",
                    "ID": "uploadStatus",
                    "width": "*",
                    "height": 24,
                    "contents": "<em style='font-size:11px;color:#888;'>No database loaded yet.</em>"
                  }
                ]
              }
            ]
          }
        ]
      },

      {
        "_type": "Label",
        "height": 18,
        "contents": "<div style='font-size:12px;color:#aaa;font-weight:600;'>Tables in database</div>"
      },
      {
        "_type": "ListGrid",
        "ID": "tablesGrid",
        "height": 120,
        "showHeader": true,
        "canEdit": false,
        "autoFitData": "horizontal",
        "emptyMessage": "Load a database to see its tables",
        "fields": [
          { "name": "name",    "title": "Table",   "width": "*" },
          { "name": "rows",    "title": "Rows",    "width": 80, "align": "right" },
          { "name": "indexes", "title": "Indexes", "width": 80, "align": "right" }
        ]
      },

      {
        "_type": "Label",
        "height": 18,
        "contents": "<div style='font-size:12px;color:#aaa;font-weight:600;'>Query (click a table to insert SELECT * FROM ...)</div>"
      },
      {
        "_type": "DynamicForm",
        "ID": "queryForm",
        "width": "100%",
        "height": 80,
        "numCols": 1,
        "fields": [
          {
            "name": "sql",
            "type": "textArea",
            "showTitle": false,
            "width": "*",
            "height": 70,
            "defaultValue": "SELECT name, department, salary FROM employees ORDER BY salary DESC"
          }
        ]
      },
      {
        "_type": "HLayout",
        "height": 28,
        "membersMargin": 8,
        "members": [
          {
            "_type": "Button",
            "ID": "btnRunQuery",
            "title": "Run Query",
            "width": 100,
            "_action": "fetchAndLoadGrid",
            "_messageType": "SQLITE_QUERY",
            "_payloadFrom": "queryForm",
            "_targetGrid": "resultsGrid",
            "_statusCanvas": "queryStatus",
            "_dynamicFields": true,
            "_timeoutMs": 60000
          },
          {
            "_type": "HTMLFlow",
            "ID": "queryStatus",
            "width": "*",
            "height": 24,
            "contents": "<em style='font-size:11px;color:#888;'>Enter a SQL query and click Run.</em>"
          }
        ]
      },

      {
        "_type": "Label",
        "height": 18,
        "contents": "<div style='font-size:12px;color:#aaa;font-weight:600;'>Query results</div>"
      },
      {
        "_type": "ListGrid",
        "ID": "resultsGrid",
        "height": "*",
        "showHeader": true,
        "canEdit": false,
        "autoFitData": "horizontal",
        "emptyMessage": "Run a query to see results here"
      }
    ]
  }
}
