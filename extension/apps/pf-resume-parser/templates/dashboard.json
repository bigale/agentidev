{
  "dataSources": [
    {
      "ID": "plugin-runs",
      "fields": [
        { "name": "id",         "type": "integer", "primaryKey": true },
        { "name": "pluginId",   "type": "text" },
        { "name": "flowName",   "type": "text" },
        { "name": "ts",         "type": "integer" },
        { "name": "durationMs", "type": "integer" },
        { "name": "success",    "type": "boolean" },
        { "name": "error",      "type": "text" },
        { "name": "sharedIn",   "type": "text" },
        { "name": "sharedOut",  "type": "text" }
      ]
    }
  ],
  "layout": {
    "_type": "VLayout",
    "ID": "pfResumeParserRoot",
    "width": "100%",
    "height": "100%",
    "padding": 12,
    "membersMargin": 8,
    "members": [
      {
        "_type": "Label",
        "height": 26,
        "contents": "<div style='font-size:16px;font-weight:600;color:#a8b4ff;'>Resume Parser <span style='font-size:11px;color:#888;font-weight:400;margin-left:8px;'>PocketFlow cookbook plugin · structured-output pattern</span></div>"
      },
      {
        "_type": "TabSet",
        "ID": "parserTabs",
        "width": "100%",
        "height": "*",
        "tabs": [
          {
            "title": "Run",
            "ID": "tabRun",
            "pane": {
              "_type": "VLayout",
              "padding": 12,
              "membersMargin": 8,
              "overflow": "auto",
              "members": [
                {
                  "_type": "DynamicForm",
                  "ID": "parseForm",
                  "width": "100%",
                  "height": 280,
                  "numCols": 2,
                  "colWidths": [70, "*"],
                  "titleOrientation": "left",
                  "fields": [
                    {
                      "name": "resume_text",
                      "title": "Resume",
                      "type": "textArea",
                      "height": 200,
                      "width": "*",
                      "defaultValue": "# JOHN SMTIH\n\n**Email:** johnsmtih1983@gnail.com\n**Phone:** (555) 123-4556\n\n## WORK EXPERIENCE\n\n### SALES MANAGER\n**ABC Corporation** | June 2018 - Present\n- Oversee a team of 12 sales representatives\n- Implemented new CRM system that improved efficiency by 15%\n- Collaborate with Marketing team on campaigns\n\n### ASSISTANT MANAGER\n**XYZ Industries** | March 2015 - May 2018\n- Managed inventory and vendor relations\n- Trained junior staff using Microsoft Office tools\n\n## EDUCATION\n**Bachelor of Business Administration** | University of Somewhere | 2010"
                    },
                    {
                      "name": "target_skills",
                      "title": "Skills",
                      "type": "textArea",
                      "height": 60,
                      "width": "*",
                      "defaultValue": "Team leadership, CRM software, Project management, Public speaking, Microsoft Office, Python, Data Analysis"
                    }
                  ]
                },
                {
                  "_type": "HLayout",
                  "height": 32,
                  "membersMargin": 8,
                  "members": [
                    {
                      "_type": "Button",
                      "ID": "btnParse",
                      "title": "Parse Resume",
                      "width": 160,
                      "_action": "dispatchAndDisplay",
                      "_messageType": "PF_RESUME_PARSE",
                      "_payloadFrom": ["parseForm", "promptForm"],
                      "_targetCanvas": "outputParsed",
                      "_resultPath": "parsed",
                      "_resultFormatter": "json",
                      "_timeoutMs": 90000
                    },
                    {
                      "_type": "Button",
                      "ID": "btnShared",
                      "title": "Show full state",
                      "width": 160,
                      "_action": "dispatchAndDisplay",
                      "_messageType": "PF_RESUME_PARSE",
                      "_payloadFrom": ["parseForm", "promptForm"],
                      "_targetCanvas": "outputShared",
                      "_resultFormatter": "json",
                      "_timeoutMs": 90000
                    },
                    {
                      "_type": "Label",
                      "width": "*",
                      "contents": "<div style='font-size:11px;color:#888;line-height:1.4;'>Skills: comma-separated. The prompt template lives on the <b>Prompt</b> tab.</div>"
                    }
                  ]
                },
                {
                  "_type": "Label",
                  "height": 16,
                  "contents": "<div style='font-size:11px;color:#666;'>Parsed fields</div>"
                },
                {
                  "_type": "HTMLFlow",
                  "ID": "outputParsed",
                  "height": 220,
                  "padding": 4,
                  "overflow": "auto",
                  "contents": "<em style='color:#888;'>Click \"Parse Resume\" to extract structured fields.</em>"
                },
                {
                  "_type": "Label",
                  "height": 16,
                  "contents": "<div style='font-size:11px;color:#666;'>Full shared state</div>"
                },
                {
                  "_type": "HTMLFlow",
                  "ID": "outputShared",
                  "height": 200,
                  "padding": 4,
                  "overflow": "auto",
                  "contents": "<em style='color:#888;'>Click \"Show full state\" for the complete response.</em>"
                }
              ]
            }
          },
          {
            "title": "Prompt",
            "ID": "tabPrompt",
            "pane": {
              "_type": "VLayout",
              "padding": 12,
              "membersMargin": 8,
              "members": [
                {
                  "_type": "Label",
                  "height": 36,
                  "contents": "<div style='font-size:12px;color:#888;line-height:1.5;'>Editable prompt sent to the LLM. Markers <code>{resume}</code> and <code>{skills}</code> are substituted at run time. Edit and click <b>Parse Resume</b> on the Run tab — the new prompt is used immediately.</div>"
                },
                {
                  "_type": "DynamicForm",
                  "ID": "promptForm",
                  "width": "100%",
                  "height": "*",
                  "numCols": 1,
                  "fields": [
                    {
                      "name": "prompt_template",
                      "title": "Prompt template",
                      "type": "textArea",
                      "height": "*",
                      "width": "*",
                      "showTitle": false,
                      "defaultValue": "Extract structured fields from the resume below.\n\n**Resume:**\n```\n{resume}\n```\n\n**Target Skills (use these indexes):**\n```\n{skills}\n```\n\nReturn:\n- name (string): full name extracted from the resume\n- email (string): email address\n- experience: array of {title, company} objects, one per job\n- skill_indexes: array of integer indexes into the target skills list, one per skill found in the resume"
                    }
                  ]
                }
              ]
            }
          },
          {
            "title": "History",
            "ID": "tabHistory",
            "pane": {
              "_type": "VLayout",
              "padding": 12,
              "membersMargin": 8,
              "members": [
                {
                  "_type": "HLayout",
                  "height": 28,
                  "membersMargin": 8,
                  "members": [
                    {
                      "_type": "Button",
                      "ID": "btnRefreshHistory",
                      "title": "Refresh",
                      "width": 100,
                      "_action": "dsFetch",
                      "_targetGrid": "runHistoryGrid"
                    },
                    {
                      "_type": "Label",
                      "width": "*",
                      "contents": "<div style='font-size:11px;color:#888;line-height:1.4;'>Every Parse run is recorded in the <code>plugin-runs</code> IndexedDB store. Survives page refresh.</div>"
                    }
                  ]
                },
                {
                  "_type": "ListGrid",
                  "ID": "runHistoryGrid",
                  "height": "*",
                  "dataSource": "plugin-runs",
                  "autoFetchData": true,
                  "criteria": { "pluginId": "pf-resume-parser" },
                  "initialCriteria": { "pluginId": "pf-resume-parser" },
                  "sortField": "ts",
                  "sortDirection": "descending",
                  "showHeader": true,
                  "canEdit": false,
                  "_replayInto": ["parseForm", "promptForm"],
                  "_replaySwitchTab": ["parserTabs", "tabRun"],
                  "emptyMessage": "No runs yet — click Parse to record one. Click any row to replay its inputs.",
                  "fields": [
                    { "name": "ts",         "title": "When",     "width": 160, "_formatter": "timestamp" },
                    { "name": "durationMs", "title": "Duration", "width": 90,  "align": "right" },
                    { "name": "success",    "title": "OK",       "width": 50,  "type": "boolean" },
                    { "name": "flowName",   "title": "Flow",     "width": 140 },
                    { "name": "error",      "title": "Error",    "width": "*"  }
                  ]
                }
              ]
            }
          }
        ]
      }
    ]
  }
}
