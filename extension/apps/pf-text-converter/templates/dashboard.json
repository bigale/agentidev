{
  "dataSources": [
    {
      "ID": "plugin-runs",
      "fields": [
        { "name": "id",         "type": "integer", "primaryKey": true },
        { "name": "pluginId",   "type": "text" },
        { "name": "flowName",   "type": "text" },
        { "name": "ts",         "type": "integer" },
        { "name": "durationMs", "type": "integer" },
        { "name": "success",    "type": "boolean" },
        { "name": "error",      "type": "text" },
        { "name": "sharedIn",   "type": "text" },
        { "name": "sharedOut",  "type": "text" }
      ]
    }
  ],
  "layout": {
    "_type": "VLayout",
    "ID": "pfTextConverterRoot",
    "width": "100%",
    "height": "100%",
    "padding": 12,
    "membersMargin": 8,
    "members": [
      {
        "_type": "Label",
        "height": 26,
        "contents": "<div style='font-size:16px;font-weight:600;color:#a8b4ff;'>Text Converter <span style='font-size:11px;color:#888;font-weight:400;margin-left:8px;'>PocketFlow cookbook plugin · 3-node Validate→Transform|Reject</span></div>"
      },
      {
        "_type": "TabSet",
        "ID": "converterTabs",
        "width": "100%",
        "height": "*",
        "tabs": [
          {
            "title": "Run",
            "ID": "tabRun",
            "pane": {
              "_type": "VLayout",
              "padding": 12,
              "membersMargin": 8,
              "overflow": "auto",
              "members": [
                {
                  "_type": "DynamicForm",
                  "ID": "convertForm",
                  "width": "100%",
                  "height": 150,
                  "numCols": 2,
                  "colWidths": [70, "*"],
                  "titleOrientation": "left",
                  "fields": [
                    {
                      "name": "text",
                      "title": "Text",
                      "type": "textArea",
                      "height": 80,
                      "width": "*",
                      "defaultValue": "  Hello from   PocketFlow  "
                    },
                    {
                      "name": "choice",
                      "title": "Op",
                      "type": "select",
                      "width": 240,
                      "defaultValue": "upper",
                      "valueMap": {
                        "upper": "Convert to UPPERCASE",
                        "lower": "Convert to lowercase",
                        "reverse": "Reverse text",
                        "collapse": "Collapse whitespace"
                      }
                    }
                  ]
                },
                {
                  "_type": "HLayout",
                  "height": 32,
                  "membersMargin": 8,
                  "members": [
                    {
                      "_type": "Button",
                      "ID": "btnRunFlow",
                      "title": "Convert (run flow)",
                      "width": 180,
                      "_action": "dispatchAndDisplay",
                      "_messageType": "PF_TEXT_CONVERT",
                      "_payloadFrom": "convertForm",
                      "_targetCanvas": "outputFlow",
                      "_resultPath": "result",
                      "_resultFormatter": "stdoutPre",
                      "_timeoutMs": 30000
                    },
                    {
                      "_type": "Button",
                      "ID": "btnShowShared",
                      "title": "Show shared state",
                      "width": 160,
                      "_action": "dispatchAndDisplay",
                      "_messageType": "PF_TEXT_CONVERT",
                      "_payloadFrom": "convertForm",
                      "_targetCanvas": "outputShared",
                      "_resultFormatter": "json",
                      "_timeoutMs": 30000
                    }
                  ]
                },
                {
                  "_type": "Label",
                  "height": 16,
                  "contents": "<div style='font-size:11px;color:#666;'>Result (extracted via <code>_resultPath: \"result\"</code>)</div>"
                },
                {
                  "_type": "HTMLFlow",
                  "ID": "outputFlow",
                  "height": 70,
                  "padding": 4,
                  "overflow": "auto",
                  "contents": "<em style='color:#888;'>Click \"Convert\" to run the flow.</em>"
                },
                {
                  "_type": "Label",
                  "height": 16,
                  "contents": "<div style='font-size:11px;color:#666;'>Full shared state (raw JSON — shows how the flow mutated state)</div>"
                },
                {
                  "_type": "HTMLFlow",
                  "ID": "outputShared",
                  "height": 200,
                  "padding": 4,
                  "overflow": "auto",
                  "contents": "<em style='color:#888;'>Click \"Show shared state\" to see the full response.</em>"
                }
              ]
            }
          },
          {
            "title": "History",
            "ID": "tabHistory",
            "pane": {
              "_type": "VLayout",
              "padding": 12,
              "membersMargin": 8,
              "members": [
                {
                  "_type": "HLayout",
                  "height": 28,
                  "membersMargin": 8,
                  "members": [
                    {
                      "_type": "Button",
                      "ID": "btnRefreshHistoryC",
                      "title": "Refresh",
                      "width": 100,
                      "_action": "dsFetch",
                      "_targetGrid": "runHistoryGridC"
                    },
                    {
                      "_type": "Label",
                      "width": "*",
                      "contents": "<div style='font-size:11px;color:#888;line-height:1.4;'>Every Convert run is recorded in the <code>plugin-runs</code> IndexedDB store. Survives page refresh.</div>"
                    }
                  ]
                },
                {
                  "_type": "ListGrid",
                  "ID": "runHistoryGridC",
                  "height": "*",
                  "dataSource": "plugin-runs",
                  "autoFetchData": true,
                  "criteria": { "pluginId": "pf-text-converter" },
                  "initialCriteria": { "pluginId": "pf-text-converter" },
                  "sortField": "ts",
                  "sortDirection": "descending",
                  "showHeader": true,
                  "canEdit": false,
                  "_replayInto": ["convertForm"],
                  "_replaySwitchTab": ["converterTabs", "tabRun"],
                  "emptyMessage": "No runs yet — click Convert to record one. Click any row to replay its inputs.",
                  "fields": [
                    { "name": "ts",         "title": "When",     "width": 160, "_formatter": "timestamp" },
                    { "name": "durationMs", "title": "Duration", "width": 90,  "align": "right" },
                    { "name": "success",    "title": "OK",       "width": 50,  "type": "boolean" },
                    { "name": "flowName",   "title": "Flow",     "width": 140 },
                    { "name": "error",      "title": "Error",    "width": "*"  }
                  ]
                }
              ]
            }
          }
        ]
      }
    ]
  }
}
