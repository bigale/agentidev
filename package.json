{
  "name": "agentidev",
  "version": "0.1.0",
  "private": true,
  "description": "Browser extension for semantic memory and activity intelligence",
  "main": "extension/background.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "test": "jest",
    "lint": "eslint extension/**/*.js",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "bridge": "node packages/bridge/server.mjs",
    "bridge:stop": "node packages/bridge/server.mjs --stop",
    "bridge:restart": "node packages/bridge/server.mjs --stop && sleep 1 && node packages/bridge/server.mjs",
    "browser": "node packages/bridge/launch-browser.mjs",
    "browser:chrome": "node packages/bridge/launch-browser.mjs --chrome",
    "browser:list": "playwright-cli list",
    "bridge:cli": "node packages/bridge/claude-client.mjs",
    "dash": "node packages/bridge/dashboard-driver.mjs",
    "dash:screenshot": "node packages/bridge/dashboard-driver.mjs screenshot",
    "dash:status": "node packages/bridge/dashboard-driver.mjs status",
    "dev:start": "bash packages/bridge/start-dev.sh",
    "dev:stop": "bash packages/bridge/start-dev.sh --stop",
    "ai:sync": "node packages/ai-context/sync.mjs",
    "ai:check": "node packages/ai-context/sync.mjs --check",
    "ai:adapt": "node packages/ai-context/adapt.mjs",
    "wiki:sync": "node scripts/sync-wiki.mjs",
    "wiki:dry-run": "node scripts/sync-wiki.mjs --dry-run",
    "zato:up": "cd docker/zato && docker compose up -d",
    "zato:down": "cd docker/zato && docker compose down",
    "zato:setup": "node docker/zato/setup-channels.mjs",
    "zato:logs": "docker logs -f agentidev-zato",
    "zato:backup": "docker exec agentidev-zato cp /opt/zato/petstore.db /opt/zato/sql/petstore-backup.db",
    "zato:reset": "cd docker/zato && docker compose down -v && docker compose up -d",
    "zato:expose": "node docker/zato/expose.mjs",
    "pod:serve": "node docker/browserpod/serve.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bigale/agentidev.git"
  },
  "keywords": [
    "browser-extension",
    "semantic-search",
    "rag",
    "vector-database",
    "knowledge-management",
    "activity-intelligence",
    "ixml",
    "wasm"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bigale/agentidev/issues"
  },
  "homepage": "https://github.com/bigale/agentidev#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.0.254",
    "copy-webpack-plugin": "^11.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.67.6",
    "@mariozechner/pi-ai": "^0.67.6",
    "@mlc-ai/web-llm": "^0.2.82",
    "@sinclair/typebox": "^0.34.49"
  }
}
