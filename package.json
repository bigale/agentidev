{
  "name": "contextual-recall",
  "version": "0.1.0",
  "description": "Browser extension for semantic memory and activity intelligence",
  "main": "extension/background.js",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "test": "jest",
    "lint": "eslint extension/**/*.js",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "bridge": "node bridge/server.mjs",
    "bridge:stop": "node bridge/server.mjs --stop",
    "bridge:restart": "node bridge/server.mjs --stop && sleep 1 && node bridge/server.mjs",
    "browser": "node bridge/launch-browser.mjs",
    "browser:chrome": "node bridge/launch-browser.mjs --chrome",
    "browser:list": "playwright-cli list",
    "bridge:cli": "node bridge/claude-client.mjs",
    "dash": "node bridge/dashboard-driver.mjs",
    "dash:screenshot": "node bridge/dashboard-driver.mjs screenshot",
    "dash:status": "node bridge/dashboard-driver.mjs status",
    "dev:start": "bash bridge/start-dev.sh",
    "dev:stop": "bash bridge/start-dev.sh --stop"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bigale/contextual-recall.git"
  },
  "keywords": [
    "browser-extension",
    "semantic-search",
    "rag",
    "vector-database",
    "knowledge-management",
    "activity-intelligence",
    "ixml",
    "wasm"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bigale/contextual-recall/issues"
  },
  "homepage": "https://github.com/bigale/contextual-recall#readme",
  "dependencies": {
    "@lancedb/lancedb": "^0.4.0",
    "@playwright/cli": "^0.1.1",
    "@xenova/transformers": "^2.17.2",
    "apache-arrow": "^14.0.0",
    "playwright-cli": "^0.262.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.254",
    "copy-webpack-plugin": "^11.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
