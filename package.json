{
  "name": "contextual-recall",
  "version": "0.1.0",
  "private": true,
  "description": "Browser extension for semantic memory and activity intelligence",
  "main": "extension/background.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "test": "jest",
    "lint": "eslint extension/**/*.js",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "bridge": "node packages/bridge/server.mjs",
    "bridge:stop": "node packages/bridge/server.mjs --stop",
    "bridge:restart": "node packages/bridge/server.mjs --stop && sleep 1 && node packages/bridge/server.mjs",
    "browser": "node packages/bridge/launch-browser.mjs",
    "browser:chrome": "node packages/bridge/launch-browser.mjs --chrome",
    "browser:list": "playwright-cli list",
    "bridge:cli": "node packages/bridge/claude-client.mjs",
    "dash": "node packages/bridge/dashboard-driver.mjs",
    "dash:screenshot": "node packages/bridge/dashboard-driver.mjs screenshot",
    "dash:status": "node packages/bridge/dashboard-driver.mjs status",
    "dev:start": "bash packages/bridge/start-dev.sh",
    "dev:stop": "bash packages/bridge/start-dev.sh --stop",
    "ai:sync": "node packages/ai-context/sync.mjs",
    "ai:check": "node packages/ai-context/sync.mjs --check",
    "ai:adapt": "node packages/ai-context/adapt.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bigale/contextual-recall.git"
  },
  "keywords": [
    "browser-extension",
    "semantic-search",
    "rag",
    "vector-database",
    "knowledge-management",
    "activity-intelligence",
    "ixml",
    "wasm"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bigale/contextual-recall/issues"
  },
  "homepage": "https://github.com/bigale/contextual-recall#readme",
  "devDependencies": {
    "@types/chrome": "^0.0.254",
    "copy-webpack-plugin": "^11.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
